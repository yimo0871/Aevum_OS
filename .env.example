# Aevum（薪火）OS - 开发环境配置
# 复制为 .env 并填入真实值

# ── 应用 ──
APP_ENV=development
APP_DEBUG=true

# ── 数据库 ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aevum
POSTGRES_USER=aevum
POSTGRES_PASSWORD=aevum_dev_password
# DATABASE_URL 为空时自动拼接上述参数
# DATABASE_URL=postgresql+asyncpg://aevum:aevum_dev_password@localhost:5432/aevum

# ── Redis / Celery ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── 安全 ──
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

# ── LLM / Embedding（火山引擎 Coding Plan）──
# 留空则使用本地 HashEmbedder（无语义，仅用于开发）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
EMBEDDING_MODEL=doubao-embedding-vision
EMBEDDING_DIMENSION=1024

# ── LLM 对话模型 ──
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ── 联邦网络 ──
NODE_URL=http://localhost:8000
NODE_ID=local

# ── 检索权重（可选调优）──
# WEIGHT_CONTEXT_SIMILARITY=0.25
# WEIGHT_SUCCESS_RATE=0.15
# WEIGHT_REUSE_COUNT=0.08
# WEIGHT_DOMAIN_DISTANCE=0.07
# WEIGHT_RECENCY=0.12
# WEIGHT_CONFIDENCE=0.13
# WEIGHT_TRUST_SCORE=0.20
