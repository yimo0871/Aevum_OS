# ──────────────────────────────────────
# Aevum（薪火）OS - Environment Variables
# ──────────────────────────────────────
# Copy this file to `.env` and fill in real values.

# ── App ──
APP_NAME=Aevum
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (PostgreSQL) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aevum
POSTGRES_USER=aevum
POSTGRES_PASSWORD=aevum_dev_password
DATABASE_URL=postgresql+asyncpg://aevum:aevum_dev_password@localhost:5432/aevum

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM / Embedding ──
# 支持 OpenAI 和火山引擎（方舟）等 OpenAI 兼容 API
# 火山引擎 Coding Plan 配置示例:
#   OPENAI_API_KEY=你的火山引擎API Key
#   OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
#   EMBEDDING_MODEL=doubao-embedding-vision
#   EMBEDDING_DIMENSION=2048
#   LLM_MODEL=doubao-seed-2-0-pro-260215
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1024

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Aevum

# ── Security ──
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]
